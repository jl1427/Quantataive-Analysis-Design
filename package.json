{
  "name": "stock-pattern-dashboard-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:e2e": "node ./scripts/prepare-e2e-db.mjs && playwright test",
    "test:e2e:headed": "node ./scripts/prepare-e2e-db.mjs && playwright test --headed",
    "test:e2e:mobile": "node ./scripts/prepare-e2e-db.mjs && playwright test --project=mobile-chromium",
    "test:e2e:live-smoke": "node ./scripts/prepare-e2e-db.mjs && PLAYWRIGHT_LIVE_SMOKE=true playwright test tests/e2e/live-smoke.spec.js --project=chromium"
  },
  "dependencies": {
    "pg": "^8.20.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "vite": "^6.2.0"
  }
}
